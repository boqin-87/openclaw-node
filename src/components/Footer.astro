---
import { SITE_AUTHOR } from '../consts';
const today = new Date();
---

<footer class="footer">
	<div class="container inner">
		<p>© {today.getFullYear()} {SITE_AUTHOR}. Built with Astro.</p>
	</div>
</footer>

<style>
	.footer {
		border-top: 1px solid var(--line);
		margin-top: 3rem;
	}
	.inner {
		padding: 1.2rem 0 2rem;
		color: var(--muted);
		font-size: 0.92rem;
	}
</style>
